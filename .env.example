# Cloudinary Configuration (server-side)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Cloudinary Configuration (client-side for upload widget)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=gallery_upload

# WebAuthn / Passkey Configuration
# Your domain without protocol (e.g., gallery.yourdomain.com or localhost for dev)
WEBAUTHN_RP_ID=localhost
# Full origin URL with protocol (e.g., https://gallery.yourdomain.com)
WEBAUTHN_ORIGIN=http://localhost:3000
# JWT secret for session tokens (min 32 characters)
JWT_SECRET=your-secret-key-min-32-chars-long-change-this
# Credential string from passkey registration (format: credentialID:publicKey)
# Leave empty initially, then add after registering your passkey
WEBAUTHN_CREDENTIAL=